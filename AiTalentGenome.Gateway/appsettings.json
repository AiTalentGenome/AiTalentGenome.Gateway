{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "IdentityUrl": "http://localhost:5101",
    "VacancyUrl": "http://localhost:5102"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/identity/{**catch-all}" }
      },
      "vacancy-route": {
        "ClusterId": "vacancy-cluster",
        "Match": { "Path": "/api/vacancy/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5101" }
        }
      },
      "vacancy-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5102" }
        }
      }
    }
  }
}
